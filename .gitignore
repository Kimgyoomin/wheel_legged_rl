# ------------------------------------------------------------------------------
# Local training artifacts and large model binaries (safety for research workflow)
# ------------------------------------------------------------------------------
# Root-level run outputs
/logs/
/wandb/
runs/
recordings/
outputs/
output/
videos/

# Also catch nested outputs (if generated under subfolders)
**/logs/
**/wandb/

# Model/checkpoint binaries
*.pt
*.pth
*.ckpt
*.onnx
*.csv



# ------------------------------------------------------------------------------
# Local robot/simulator assets
# ------------------------------------------------------------------------------
# Keep robot USD/URDF/mesh/collision assets out of GitHub.
# These files are large, frequently regenerated, and machine/project-specific.
/assets/
assets/
**/assets/

# Extra guard for robot asset formats
*.stl
*.STL
*.obj
*.dae
*.fbx
*.glb
*.gltf
*.mtl
